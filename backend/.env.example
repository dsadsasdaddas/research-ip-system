# 复制本文件为 .env 并按需修改(.env 不进 git)
PORT=3001

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root1234
DB_NAME=research_db

# JWT 密钥 — 生产环境务必修改为随机长字符串！
# 可用命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here

# ── 定时备份(§4 数据备份) ──
# BACKUP_ENABLED=true 时启用每天全量备份 + 30 天保留清理;未设/非 true 则跳过(不报错)
# BACKUP_ENABLED=true
# 5 字段 cron,默认每天 02:00
# BACKUP_CRON=0 2 * * *

# ── Redis 缓存(可选) ──
# 仅当设置 REDIS_HOST 时启用 CacheModule;未设则不启用缓存,应用照常启动
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
